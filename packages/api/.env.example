# Stellar payment recipient (your public key)
STELLAR_RECIPIENT=G...

# Random string for mppx credential verification (NOT a Stellar key)
MPP_SECRET_KEY=change_me_to_any_random_string

# Backend API keys (server-side only, users never see these)
BRAVE_API_KEY=
EXA_API_KEY=
YOUTUBE_API_KEY=
SCREENSHOTONE_KEY=
OPENAI_API_KEY=
ALPHA_VANTAGE_KEY=
OPENWEATHER_API_KEY=

# Optional
PORT=3000
