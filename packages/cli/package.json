{
  "name": "@xlmtools/cli",
  "version": "0.2.3",
  "description": "XLMTools standalone CLI — the `xlm` command plus the `createMcpServer` factory used by the @xlmtools/mcp wrapper package.",
  "type": "module",
  "bin": {
    "xlm": "dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stellar/mpp": "^0.4.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "mppx": "^0.5.5",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "stellar",
    "xlm",
    "cli",
    "soroban",
    "mpp",
    "x402",
    "agent-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Blockchain-Oracle/xlmtools.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  }
