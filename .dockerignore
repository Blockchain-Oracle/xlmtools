# Dependencies — never ship, Docker reinstalls fresh
node_modules
packages/*/node_modules
.pnpm-store

# Build output — nixpacks/Docker generates these inside the image
dist
packages/*/dist
**/.next
**/.turbo
packages/docs/public/_pagefind

# Environment files — secrets live in Coolify, not the tarball
.env
*.env
packages/**/.env
packages/**/*.env

# Version control
.git
.gitignore
.github

# Editor and OS
.DS_Store
.vscode
.idea
*.log
pnpm-debug.log

# Test artifacts
coverage
packages/*/coverage

# Local dev
*.local
deployment.md

# Internal assets / notes — not needed at runtime, just bloat the image
screenshots
research
docs/superpowers
.agents
.claude
.mcp.json
skills-lock.json
tests
VIDEO-SCRIPT.md
