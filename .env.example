# API Server (packages/api/.env)
PORT=3000

# Stellar — public key that receives USDC payments from users
STELLAR_RECIPIENT=G...
# Random string for mppx credential verification (NOT a Stellar key — just any strong random string)
MPP_SECRET_KEY=replace-with-random-string

# Tool API Keys
BRAVE_API_KEY=
EXA_API_KEY=
YOUTUBE_API_KEY=
SCREENSHOTONE_KEY=
OPENAI_API_KEY=
ALPHA_VANTAGE_KEY=
OPENWEATHER_API_KEY=
